# Runtime mode: demo requires no external services; full enables Dify/PostgreSQL/APIs.
INSPITRIP_MODE=demo

# Dify application (required only in full mode)
DIFY_WEBAPP_PUBLIC_URL=
DIFY_APP_API_BASE=http://localhost/v1
DIFY_APP_API_KEY=

# Dify destination knowledge
DIFY_API_BASE=http://localhost/v1
DIFY_DESTINATION_DATASET_ID=
DIFY_DATASET_API_KEY=

# Amap Web Service
AMAP_KEY=

# Xinference local models (use actual model IDs from GET /v1/models)
XINFERENCE_BASE_URL=http://127.0.0.1:9997/v1
XINFERENCE_CHAT_MODEL=glm4-chat
XINFERENCE_EMBEDDING_MODEL=bge-m3
XINFERENCE_RERANK_MODEL=bge-reranker
CLAIM_RERANK_TIMEOUT_SECONDS=5
CLAIM_RERANK_MIN_SCORE=0.1

# OpenAI-compatible aliases used by the annotation pipeline
OPENAI_API_KEY=local-xinference
OPENAI_BASE_URL=http://127.0.0.1:9997/v1
OPENAI_MODEL=glm4-chat

# PostgreSQL
DATABASE_URL=

# Tavily
TAVILY_API_KEY=
