{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InspiTrip 目的地画像 Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "destination_id", "name", "aliases", "city", "province", "category",
    "status", "mood_scores", "vibe_scores", "activity_scores",
    "core_feeling", "atmosphere", "suitable_scenes", "activities",
    "limitations", "positive_evidence_count", "limitation_evidence_count",
    "evidence_quality", "freshness_score", "private_discovery_value",
    "source_count", "metadata"
  ],
  "properties": {
    "destination_id": {"type": "string"},
    "name": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "city": {"type": "string"},
    "province": {"type": "string"},
    "category": {"type": "string"},
    "status": {"type": "string"},
    "mood_scores": {"type": "object", "additionalProperties": {"type": "number"}},
    "vibe_scores": {"type": "object", "additionalProperties": {"type": "number"}},
    "activity_scores": {"type": "object", "additionalProperties": {"type": "number"}},
    "core_feeling": {"type": "string"},
    "atmosphere": {"type": "string"},
    "suitable_scenes": {"type": "array", "items": {"type": "string"}},
    "activities": {"type": "array", "items": {"type": "string"}},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "positive_evidence_count": {"type": "integer", "minimum": 0},
    "limitation_evidence_count": {"type": "integer", "minimum": 0},
    "evidence_quality": {"type": "number", "minimum": 0, "maximum": 1},
    "freshness_score": {"type": "number", "minimum": 0, "maximum": 1},
    "private_discovery_value": {"type": "number", "minimum": 0, "maximum": 1},
    "source_count": {"type": "integer", "minimum": 0},
    "metadata": {"type": "object", "additionalProperties": true}
  }
}
