{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InspiTrip 推荐实体 Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id", "legacy_poi_id", "legacy_poi_ids", "entity_type", "parent_id", "name",
    "aliases", "city", "province", "status"
  ],
  "properties": {
    "entity_id": {"type": "string"},
    "legacy_poi_id": {"type": "string"},
    "legacy_poi_ids": {"type": "array", "items": {"type": "string"}},
    "entity_type": {
      "type": "string",
      "enum": ["destination", "experience", "service", "transport_node"]
    },
    "parent_id": {"type": ["string", "null"]},
    "name": {"type": "string"},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "city": {"type": "string"},
    "province": {"type": "string", "enum": ["上海", "江苏", "浙江"]},
    "category": {"type": "string"},
    "longitude": {"type": ["number", "null"]},
    "latitude": {"type": ["number", "null"]},
    "map_poi_id": {"type": ["string", "null"]},
    "standard_province": {"type": "string"},
    "standard_city": {"type": "string"},
    "standard_district": {"type": "string"},
    "adcode": {"type": "string"},
    "address": {"type": "string"},
    "telephone": {"type": "string"},
    "business_area": {"type": "string"},
    "opening_hours": {"type": "string"},
    "operational_status": {"type": "string"},
    "map_match_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "map_match_level": {"enum": ["high", "medium", "low", "unknown"]},
    "geocode_status": {"enum": ["pending", "matched", "region_geocoded", "review_required", "no_match", "api_failed", "manual_override", "excluded"]},
    "map_review_status": {"enum": ["review_required", "auto_approved", "manual_approved", "manual_approved_region", "excluded"]},
    "map_checked_at": {"type": ["string", "null"]},
    "map_source": {"type": "string"},
    "status": {"type": "string", "enum": ["active", "inactive", "unknown"]}
  }
}
