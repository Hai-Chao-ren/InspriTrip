{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InspiTrip Query State Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "plan", "clarification_count", "pending_clarification"],
  "properties": {
    "version": {"const": "1.0"},
    "plan": {"type": "object"},
    "clarification_count": {"type": "integer", "minimum": 0, "maximum": 1},
    "pending_clarification": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["question", "missing_slots"],
          "properties": {
            "question": {"type": "string", "minLength": 1},
            "missing_slots": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            }
          }
        }
      ]
    }
  },
  "definitions": {
    "queryDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query_plan", "explicit_slots", "clear_slots", "replace_slots", "raw_query"],
      "properties": {
        "query_plan": {"type": "object"},
        "explicit_slots": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "clear_slots": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "replace_slots": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "raw_query": {"type": "string"}
      }
    }
  }
}
